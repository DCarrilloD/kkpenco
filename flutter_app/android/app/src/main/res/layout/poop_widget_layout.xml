<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/poop_widget_background"
    android:padding="8dp"
    android:gravity="center">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KKpenco Express ⚡"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Botón Cabra -->
        <LinearLayout
            android:id="@+id/btn_cabra"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            
            <ImageView
                android:id="@+id/img_cabra"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Cabra"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cabra"
                android:textColor="#8D6E63"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Botón Espurruteo -->
        <LinearLayout
            android:id="@+id/btn_espurruteo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            
            <ImageView
                android:id="@+id/img_espurruteo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Espurruteo"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Espurruteo"
                android:textColor="#64B5F6"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Botón Normal -->
        <LinearLayout
            android:id="@+id/btn_normal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            
            <ImageView
                android:id="@+id/img_normal"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Normal"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Normal"
                android:textColor="#81C784"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Botón Jurásica -->
        <LinearLayout
            android:id="@+id/btn_jurasica"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            
            <ImageView
                android:id="@+id/img_jurasica"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Jurásica"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jurásica"
                android:textColor="#FFB74D"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
